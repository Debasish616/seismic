{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Seismic Cards API",
  "logo": {
    "light": "/logo/light.svg",
    "dark":  "/logo/dark.svg",
    "href":  "https://docs.seismic-cards.systems"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary":    "#0D0D0D",
    "light":      "#FAFAFA",
    "dark":       "#0D0D0D",
