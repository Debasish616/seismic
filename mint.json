  "modeToggle": {
    "default":           "dark",
    "isHidden":          false
  },
  "topbarLinks": [
    {
      "name": "Status",
      "url":  "https://status.seismic-cards.systems"
    },
    {
      "name": "Support",
      "url":  "mailto:support@seismic-cards.systems"
    }
  ],
  "topbarCtaButton": {
    "name": "Talk to Sales",
    "url":  "https://www.seismic-cards.systems"
  },
  "primaryTab": {
    "name": "Documentation"
  },
  "tabs": [
    {
      "name": "API Reference",
      "url":  "api-reference"
    }
  ],
  "anchors": [
    {
      "name": "Issue your first card",
      "icon": "credit-card",
      "url":  "issuing-a-card"
    },
    {
      "name": "Roadmap",
      "icon": "map",
      "url":  "webhooks"
    }
  ],
  "navigation": [
    {
      "group": "Get started",
      "pages": [
        "introduction",
        "getting-started"
      ]
    },
    {
      "group": "Guides",
      "pages": [
        "issuing-a-card"
      ]
    },
    {
      "group": "Reference",
      "pages": [
        "api-reference",
        "errors"
      ]
    },
    {
      "group": "Roadmap",
      "pages": [
        "webhooks",
        "pci-widget"
      ]
    }
  ],
  "footerSocials": {
    "website":  "https://www.seismic-cards.systems",
    "x":        "https://x.com/seismicsys",
    "linkedin": "https://www.linkedin.com/company/seismicsystems"
  },
  "feedback": {
    "thumbsRating":   true,
    "suggestEdit":    true,
    "raiseIssue":     true
  },
  "search": {
    "prompt": "Search the Seismic Cards docs…"
  },
  "seo": {
    "indexHiddenPages": false
  },
  "metadata": {
    "og:title":       "Seismic Cards API",
    "og:description": "Issue Visa / Mastercard virtual cards. PCI-compliant card issuing platform with sub-accounts, KYC, cardholders, budgets, real-time webhooks, and a drop-in widget for displaying full card details.",
    "og:image":       "/logo/og.png"
  }
